{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/static/(.*)",
      "destination": "/client/static/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/client/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "/client/manifest.json"
    },
    {
      "source": "/logo192.png",
      "destination": "/client/logo192.png"
    },
    {
      "source": "/logo512.png",
      "destination": "/client/logo512.png"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ]
}